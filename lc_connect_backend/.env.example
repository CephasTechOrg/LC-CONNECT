APP_NAME=LC Connect API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────────
# Local development (PostgreSQL running locally)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lc_connect_db

# Production (Supabase — use Transaction pooler port 6543, NOT 5432)
# DATABASE_URL=postgresql+asyncpg://postgres.YOURPROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://127.0.0.1:3000,http://127.0.0.1:8081

# ── Supabase (Storage + Realtime) ─────────────────────────────────
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_PROFILE_BUCKET=profile-images
MAX_PROFILE_IMAGE_MB=5

# ── Email provider ────────────────────────────────────────────────
# auto | resend | smtp | console
# "auto" picks Resend if RESEND_API_KEY is set, else SMTP if credentials are set, else console.
EMAIL_PROVIDER=auto

# Resend (primary — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=LC Connect <noreply@yourdomain.com>
RESEND_REPLY_TO=support@yourdomain.com

# SMTP (fallback — e.g. Gmail App Password)
# To create a Gmail App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=LC Connect <your-gmail@gmail.com>
SMTP_TLS=true
